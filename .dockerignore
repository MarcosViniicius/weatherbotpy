# ════════════════════════════════════════════════════════════
# .dockerignore — Exclude files from Docker build context
# Reduces image size and build time
# ════════════════════════════════════════════════════════════

# Version control
.git
.gitignore
.gitattributes

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv
ENV/
env/

# IDEs
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
.sublime-project
.sublime-workspace
*.iml

# Test files
tests/
test_*.py
*_test.py
.pytest_cache/

# Documentation
docs/
*.md
README.md
CHANGELOG.md

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Node/npm (if any frontend deps)
node_modules/
package-lock.json
npm-debug.log

# Temporary files
*.tmp
*.log
*.pid
tmp/
temp/

# Environment files (.env will be injected at runtime)
.env.local
.env.*.local

# OS files
Thumbs.db
.DS_Store

# Debug files
debug_output.txt
tmp_debug.py
tmp_out.txt

# Misc
.vscode-settings
.history/
*.orig
