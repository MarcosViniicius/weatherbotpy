# ============================================================
# WeatherBet v3 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# ============================================================

# --- Bot Mode ---
# "simulation" (default) or "production"
# Can also be changed via Telegram /production command
BOT_MODE=simulation

# --- Telegram ---
# Create a bot via @BotFather on Telegram to get the token
# Your personal chat ID (send /start to @userinfobot to find it)
TELEGRAM_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# --- Polymarket (Production mode only) ---
# Private key of your Polygon wallet (with USDC on Polymarket)
# For EOA wallets (MetaMask, hardware wallets): signature_type=0
# For email/Magic wallets: signature_type=1
# For proxy wallets: signature_type=2
POLYMARKET_PRIVATE_KEY=your-private-key-here
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=0

# --- Weather APIs ---
# Visual Crossing — free tier at https://www.visualcrossing.com/weather-api
# Used for actual temperature after market resolution
VC_KEY=visual-crossing-key-here

# --- Dashboard ---
# Leave empty for localhost only, or set to your VPS IP/domain to access remotely
# Example for VPS: DASHBOARD_PUBLIC_URL=your-vps-domain.com or 123.45.67.89
DASHBOARD_PUBLIC_URL=
DASHBOARD_PORT=8877
# Enable HTTP Basic Authentication (set to true to enable)
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme

# --- Risk Parameters ---
# Moved to TOML: risk.toml (project root)
# Edit directly in file, or via Telegram:
#   /risk
#   /setrisk <key> <value>
#
# Legacy ENV fallback (optional if TOML is missing):
# BALANCE=20.0
# MAX_BET=2.0
# MIN_EDGE=0.07
# MAX_PRICE=0.60
# MIN_VOLUME=200
# MIN_HOURS=2.0
# MAX_HOURS=72.0
# KELLY_FRACTION=0.25
# MAX_SLIPPAGE=0.02
# SCAN_INTERVAL=900
# CALIBRATION_MIN=50

# --- API Timeouts (seconds) ---
# Increase if experiencing timeouts on international VPS
POLYMARKET_TIMEOUT=15
WEATHER_TIMEOUT=15

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
#
# 1. COPY THIS FILE:
#    cp .env.example .env
#
# 2. EDIT .env WITH YOUR VALUES:
#    - Telegram: Get from @BotFather and @userinfobot
#    - Polymarket: Your wallet private key (for live trading)
#    - Weather: API keys for enhanced accuracy
#
# 3. SECURE IT:
#    - Add .env to .gitignore (echo ".env" >> .gitignore)
#    - Never commit to git
#    - Never share .env with others
#
# 4. RUN WITH DOCKER:
#    docker-compose up -d
#    (env_file: .env is automatically loaded)
#
# 5. RUN LOCALLY:
#    export $(cat .env | xargs)
#    python main.py
#
# ============================================================
# REQUIRED VS OPTIONAL
# ============================================================
#
# REQUIRED (bot won't start without these):
#   - TELEGRAM_TOKEN
#   - TELEGRAM_CHAT_ID
#   - BOT_MODE
#
# REQUIRED FOR LIVE TRADING:
#   - POLYMARKET_PRIVATE_KEY (must have USDC on Polymarket)
#   - Test in simulation mode first!
#
# OPTIONAL BUT RECOMMENDED:
#   - VC_KEY (weather enrichment)
#   - DASHBOARD_PUBLIC_URL (remote access)
#   - DASHBOARD_AUTH_ENABLED (security)
#
# ============================================================
# SECURITY CHECKLIST
# ============================================================
#
# ⚠️  BEFORE DEPLOYING TO VPS:
#
# [ ] .env is in .gitignore
# [ ] TELEGRAM_TOKEN is correct (from @BotFather)
# [ ] DASHBOARD_PASSWORD is changed from 'changeme'
# [ ] DASHBOARD_AUTH_ENABLED=true (if exposed to internet)
# [ ] BOT_MODE=simulation for testing first
# [ ] Firewall limits dashboard access (port 8877)
#
# ⚠️  BEFORE LIVE TRADING:
#
# [ ] Tested thoroughly in simulation mode
# [ ] Confirmed balance is sufficient (MIN: $5, RECOMMENDED: $50+)
# [ ] POLYMARKET_PRIVATE_KEY is correct
# [ ] KELLY_FRACTION is conservative (0.1-0.25)
# [ ] MAX_BET is reasonable (e.g., 10% of balance)
# [ ] Monitoring Telegram notifications closely
#
# ============================================================
# API KEY SOURCES
# ============================================================
#
# TELEGRAM_TOKEN:
#   → https://t.me/botfather
#   → /start → /newbot → follow steps
#   → Get token from bot creation message
#
# TELEGRAM_CHAT_ID:
#   → https://t.me/userinfobot
#   → /start
#   → Bot replies with your ID
#
# VC_KEY (Visual Crossing):
#   → https://www.visualcrossing.com/
#   → Sign up for free account
#   → API Keys section → Copy key
#   → Free tier: 1000 calls/day
#
# POLYMARKET_PRIVATE_KEY:
#   → MetaMask or similar wallet
#   → Account Details → Export Private Key
#   → Has funds in USDC on Polygon network
#   → NEVER share this with anyone!
#
# ============================================================
# COMMON MISTAKES
# ============================================================
#
# ❌ Forgot to change BOT_MODE to simulation for testing
#    → Bot tries live trading immediately
#    → FIX: Set BOT_MODE=simulation first
#
# ❌ POLYMARKET_PRIVATE_KEY is empty but BOT_MODE=production
#    → Bot crashes immediately
#    → FIX: Either get private key or use simulation mode
#
# ❌ TELEGRAM_TOKEN is wrong
#    → "Unauthorized" error in logs
#    → FIX: Verify token from @BotFather, copy correctly
#
# ❌ .env committed to git (now exposed!)
#    → Delete from git history: git rm --cached .env
#    → Add to .gitignore: echo ".env" >> .gitignore
#
# ❌ DASHBOARD_PASSWORD still 'changeme' on exposed VPS
#    → Anyone can log in!
#    → FIX: Change password before deploying
#
# ============================================================
# TROUBLESHOOTING
# ============================================================
#
# Bot won't start:
#   1. Check logs: docker-compose logs weatherbot
#   2. Verify TELEGRAM_TOKEN is correct
#   3. Check for typos in API keys
#   4. Ensure .env is in same directory as docker-compose.yml
#
# Can't reach dashboard:
#   1. Check port: docker-compose logs | grep "binding"
#   2. Test locally: curl http://localhost:8877
#   3. Check firewall: sudo ufw allow 8877/tcp
#   4. Verify DASHBOARD_PUBLIC_URL is set for remote access
#
# Timeout errors on API calls:
#   1. Increase POLYMARKET_TIMEOUT to 20-30
#   2. Increase WEATHER_TIMEOUT to 20-30
#   3. Check internet connectivity
#   4. VPS network might be slower than local machine
#
# No trades executing:
#   1. Check bot logs for error messages
#   2. Verify edge > MIN_EDGE (default 7%)
#   3. Confirm market volume > MIN_VOLUME (default 200)
#   4. Try simulation mode first to verify logic
#
# ============================================================
# EXAMPLE CONFIGURATIONS
# ============================================================
#
# CONSERVATIVE (Low Risk):
#   BOT_MODE=simulation
#   BALANCE=20.0
#   MAX_BET=1.0
#   MIN_EDGE=0.10
#   KELLY_FRACTION=0.10
#
# MODERATE (Balanced):
#   BOT_MODE=production
#   BALANCE=50.0
#   MAX_BET=5.0
#   MIN_EDGE=0.07
#   KELLY_FRACTION=0.20
#
# AGGRESSIVE (High Risk - NOT RECOMMENDED):
#   BOT_MODE=production
#   BALANCE=100.0
#   MAX_BET=20.0
#   MIN_EDGE=0.05
#   KELLY_FRACTION=0.30
#
# ============================================================

